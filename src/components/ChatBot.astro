---
---

<section id="asistente" class="relative py-20 md:py-32 overflow-hidden" style="background:var(--ink);color:var(--cream);">
  <div class="absolute inset-0 noise-bg"></div>

  <div class="max-w-[1440px] mx-auto px-6 md:px-10 relative z-10">

    <!-- Editorial header -->
    <div class="grid grid-cols-12 gap-4 md:gap-8 mb-14 md:mb-16 fade-up">
      <div class="col-span-12 md:col-span-3">
        <div class="eyebrow eyebrow-dot mb-4" style="color:var(--gold);">Di&aacute;logo</div>
        <div class="hairline w-16" style="background:var(--cream);opacity:0.3;"></div>
      </div>
      <div class="col-span-12 md:col-span-9">
        <h2 class="display-lg" style="color:var(--cream);">
          &iquest;No sabes qu&eacute; necesitas?
          <br/>
          <span class="italic-accent" style="color:var(--gold);">Preg&uacute;ntale</span> a nuestra IA.
        </h2>
        <p class="mt-6 max-w-xl text-base md:text-lg leading-relaxed" style="color:rgba(244,239,227,0.55);">
          Cu&eacute;ntale tu desaf&iacute;o al asistente digital de Platonia y recibe un diagn&oacute;stico personalizado con la soluci&oacute;n ideal para tu negocio.
        </p>
      </div>
    </div>

    <!-- Chat container editorial -->
    <div class="fade-up max-w-[760px] mx-auto">
      <div id="chat-container" class="chat-box">
        <div class="chat-header">
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 flex items-center justify-center rounded-full" style="background:var(--gold);color:var(--ink);">
              <span class="italic" style="font-family:var(--font-display);font-weight:500;font-size:1.1rem;font-variation-settings:'opsz' 144, 'SOFT' 100, 'WONK' 1;">P</span>
            </div>
            <div>
              <div class="text-sm font-medium" style="color:var(--cream);font-family:var(--font-display);">
                Asistente <span class="italic" style="color:var(--gold);">Platonia</span>
              </div>
              <div class="flex items-center gap-1.5 mt-0.5">
                <span class="w-1.5 h-1.5 rounded-full" style="background:#22c55e;animation:pulse-whatsapp 2s ease-in-out infinite;"></span>
                <span class="marginalia" style="color:rgba(244,239,227,0.5);font-size:0.65rem;">En l&iacute;nea &bull; GPT-IA</span>
              </div>
            </div>
          </div>
          <div class="hidden md:block marginalia" style="color:rgba(244,239,227,0.4);">
            Captura I &mdash;
          </div>
        </div>

        <div id="chat-messages" class="chat-messages"></div>

        <div id="chat-typing" class="chat-typing" style="display:none;">
          <div class="typing-bubble">
            <span class="typing-dot"></span>
            <span class="typing-dot"></span>
            <span class="typing-dot"></span>
          </div>
        </div>

        <div class="chat-input-area">
          <div class="chat-input-wrapper">
            <textarea id="chat-input" class="chat-input" placeholder="Escribe tu mensaje..." rows="1" maxlength="500"></textarea>
            <span id="char-count" class="char-count" style="display:none;">500</span>
            <button id="chat-send" class="chat-send" aria-label="Enviar mensaje">
              <svg id="send-icon" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
              <svg id="send-spinner" class="w-4 h-4 animate-spin" style="display:none;" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
            </button>
          </div>
        </div>

        <div id="chat-limit" class="chat-limit" style="display:none;">
          <p>Para continuar la conversaci&oacute;n, d&eacute;janos tus datos y te contactamos personalmente.</p>
          <a href="#contacto" class="btn-primary !py-2.5 !px-6 !text-sm mt-5 touch-manipulation">Ir al formulario</a>
        </div>
      </div>

      <!-- Editorial caption -->
      <div class="flex justify-between mt-5 marginalia" style="color:rgba(244,239,227,0.4);">
        <span>Fig. 02 &mdash; Interfaz conversacional</span>
        <span>&darr; Escribe o usa las sugerencias</span>
      </div>
    </div>
  </div>
</section>

<script>
  const messagesEl = document.getElementById('chat-messages')!;
  const inputEl = document.getElementById('chat-input') as HTMLTextAreaElement;
  const sendBtn = document.getElementById('chat-send') as HTMLButtonElement;
  const sendIcon = document.getElementById('send-icon')!;
  const sendSpinner = document.getElementById('send-spinner')!;
  const typingEl = document.getElementById('chat-typing')!;
  const charCount = document.getElementById('char-count')!;
  const limitEl = document.getElementById('chat-limit')!;

  interface ChatMsg { role: 'user' | 'assistant'; content: string; }
  const messages: ChatMsg[] = [];
  let isStreaming = false;
  let userMsgCount = 0;
  let cooldownActive = false;
  const MAX_MESSAGES = 20;
  const WELCOME = '¡Hola! Soy el asistente digital de Platonia. Cuéntame sobre tu negocio y qué desafío digital enfrentas, y te ayudaré a encontrar la mejor solución.';

  const bubbleStyles: Record<string, string> = {
    assistant: 'background:#FAF7F0;color:#1A1614;border-radius:4px 16px 16px 16px;max-width:82%;padding:14px 18px;font-size:14.5px;line-height:1.55;word-break:break-word;font-family:var(--font-sans);border:1px solid rgba(26,22,20,0.08);',
    user: 'background:transparent;color:rgba(244,239,227,0.95);border:1px solid rgba(244,239,227,0.18);border-radius:16px 4px 16px 16px;max-width:82%;padding:14px 18px;font-size:14.5px;line-height:1.55;word-break:break-word;font-family:var(--font-sans);',
  };

  function addMessage(role: 'user' | 'assistant', content: string) {
    const optMatch = content.match(/\[OPCIONES:\s*(.+?)\]/);
    let cleanContent = content;
    let options: string[] = [];
    if (optMatch) {
      cleanContent = content.replace(optMatch[0], '').trim();
      options = optMatch[1].split('|').map(o => o.trim());
    }

    const wrapper = document.createElement('div');
    wrapper.style.cssText = `display:flex;${role === 'user' ? 'justify-content:flex-end;' : 'justify-content:flex-start;flex-direction:column;align-items:flex-start;'}`;

    const bubble = document.createElement('div');
    bubble.style.cssText = bubbleStyles[role];
    bubble.textContent = cleanContent;
    wrapper.appendChild(bubble);

    if (options.length > 0 && role === 'assistant') {
      const optContainer = document.createElement('div');
      optContainer.style.cssText = 'display:flex;flex-wrap:wrap;gap:6px;margin-top:10px;padding-left:4px;';
      options.forEach(opt => {
        const btn = document.createElement('button');
        btn.style.cssText = 'background:transparent;color:var(--gold);border:1px solid rgba(201,168,118,0.5);border-radius:999px;padding:7px 15px;font-size:12.5px;font-weight:500;cursor:pointer;font-family:var(--font-sans);letter-spacing:0.01em;transition:all 0.3s;';
        btn.textContent = opt;
        btn.addEventListener('mouseover', () => { btn.style.background = 'var(--gold)'; btn.style.color = 'var(--ink)'; });
        btn.addEventListener('mouseout', () => { btn.style.background = 'transparent'; btn.style.color = 'var(--gold)'; });
        btn.addEventListener('click', () => { optContainer.remove(); sendMessage(opt); });
        optContainer.appendChild(btn);
      });
      wrapper.appendChild(optContainer);
    }

    messagesEl.appendChild(wrapper);
    messagesEl.scrollTop = messagesEl.scrollHeight;
    return bubble;
  }

  function createStreamBubble(): HTMLDivElement {
    const wrapper = document.createElement('div');
    wrapper.style.cssText = 'display:flex;justify-content:flex-start;flex-direction:column;align-items:flex-start;';
    const bubble = document.createElement('div');
    bubble.style.cssText = bubbleStyles.assistant;
    wrapper.appendChild(bubble);
    messagesEl.appendChild(wrapper);
    return bubble;
  }

  function setLoading(loading: boolean) {
    isStreaming = loading;
    inputEl.disabled = loading;
    sendBtn.disabled = loading;
    sendIcon.style.display = loading ? 'none' : 'block';
    sendSpinner.style.display = loading ? 'block' : 'none';
    typingEl.style.display = loading ? 'flex' : 'none';
    if (loading) messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  async function sendMessage(text: string) {
    if (isStreaming || cooldownActive || !text.trim()) return;
    if (userMsgCount >= MAX_MESSAGES) { limitEl.style.display = 'flex'; return; }

    userMsgCount++;
    const userMsg = text.trim();
    addMessage('user', userMsg);
    messages.push({ role: 'user', content: userMsg });
    inputEl.value = '';
    inputEl.style.height = 'auto';
    charCount.style.display = 'none';
    setLoading(true);

    try {
      const res = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messages }),
      });

      if (!res.ok) {
        const data = await res.json().catch(() => ({}));
        throw new Error(data.error || 'server_error');
      }

      typingEl.style.display = 'none';
      const bubble = createStreamBubble();
      let fullText = '';

      const reader = res.body!.getReader();
      const decoder = new TextDecoder();
      let buffer = '';

      while (true) {
        const { done, value } = await reader.read();
        if (done) break;
        buffer += decoder.decode(value, { stream: true });
        const lines = buffer.split('\n');
        buffer = lines.pop() || '';
        for (const line of lines) {
          if (!line.startsWith('data: ')) continue;
          const payload = line.slice(6).trim();
          if (payload === '[DONE]') continue;
          try {
            const { text: chunk } = JSON.parse(payload);
            if (chunk) {
              fullText += chunk;
              const optCheck = fullText.match(/\[OPCIONES:\s*(.+?)\]/);
              bubble.textContent = optCheck ? fullText.replace(optCheck[0], '').trim() : fullText;
              messagesEl.scrollTop = messagesEl.scrollHeight;
            }
          } catch {}
        }
      }

      messages.push({ role: 'assistant', content: fullText });

      const optMatch = fullText.match(/\[OPCIONES:\s*(.+?)\]/);
      if (optMatch) {
        bubble.textContent = fullText.replace(optMatch[0], '').trim();
        const options = optMatch[1].split('|').map((o: string) => o.trim());
        const optContainer = document.createElement('div');
        optContainer.style.cssText = 'display:flex;flex-wrap:wrap;gap:6px;margin-top:10px;padding-left:4px;';
        options.forEach((opt: string) => {
          const btn = document.createElement('button');
          btn.style.cssText = 'background:transparent;color:var(--gold);border:1px solid rgba(201,168,118,0.5);border-radius:999px;padding:7px 15px;font-size:12.5px;font-weight:500;cursor:pointer;font-family:var(--font-sans);letter-spacing:0.01em;transition:all 0.3s;';
          btn.textContent = opt;
          btn.addEventListener('mouseover', () => { btn.style.background = 'var(--gold)'; btn.style.color = 'var(--ink)'; });
          btn.addEventListener('mouseout', () => { btn.style.background = 'transparent'; btn.style.color = 'var(--gold)'; });
          btn.addEventListener('click', () => { optContainer.remove(); sendMessage(opt); });
          optContainer.appendChild(btn);
        });
        bubble.parentElement!.appendChild(optContainer);
      }

    } catch (err: any) {
      typingEl.style.display = 'none';
      let errorMsg = 'Hubo un problema de conexión. Inténtalo de nuevo o déjanos tu consulta en el formulario.';
      if (err.message === 'rate_limit') errorMsg = 'Nuestro asistente está recibiendo muchas consultas. Intenta de nuevo en un minuto.';
      if (err.message === 'API key no configurada') errorMsg = 'Nuestro asistente está en mantenimiento. Puedes dejarnos tu consulta en el formulario.';
      addMessage('assistant', errorMsg);
      messages.push({ role: 'assistant', content: errorMsg });
    }

    setLoading(false);
    cooldownActive = true;
    setTimeout(() => { cooldownActive = false; }, 2000);
    if (userMsgCount >= MAX_MESSAGES) {
      limitEl.style.display = 'flex';
      inputEl.disabled = true;
    }
  }

  inputEl.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      sendMessage(inputEl.value);
    }
  });

  sendBtn.addEventListener('click', () => sendMessage(inputEl.value));

  inputEl.addEventListener('input', () => {
    inputEl.style.height = 'auto';
    inputEl.style.height = Math.min(inputEl.scrollHeight, 100) + 'px';
    const remaining = 500 - inputEl.value.length;
    if (remaining < 50) {
      charCount.style.display = 'block';
      charCount.textContent = remaining.toString();
      charCount.style.color = remaining < 10 ? '#ef4444' : '#C9A876';
    } else {
      charCount.style.display = 'none';
    }
  });

  addMessage('assistant', WELCOME);
</script>

<style>
  .chat-box {
    background: rgba(26, 22, 20, 0.5);
    -webkit-backdrop-filter: blur(16px);
    backdrop-filter: blur(16px);
    border-radius: 6px;
    border: 1px solid rgba(244, 239, 227, 0.1);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .chat-header {
    background: rgba(244, 239, 227, 0.03);
    padding: 16px 20px;
    border-bottom: 1px solid rgba(244, 239, 227, 0.08);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .chat-messages {
    padding: 20px;
    overflow-y: auto;
    max-height: 440px;
    min-height: 200px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    scroll-behavior: smooth;
  }
  @media (max-width: 640px) {
    .chat-messages { max-height: 55vh; }
  }

  .chat-typing { padding: 8px 20px; display: flex; }
  .typing-bubble {
    background: #FAF7F0;
    border: 1px solid rgba(26,22,20,0.08);
    border-radius: 4px 16px 16px 16px;
    padding: 12px 18px;
    display: flex;
    gap: 5px;
    align-items: center;
  }
  .typing-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--plum);
    animation: typingBounce 1.4s ease-in-out infinite;
  }
  .typing-dot:nth-child(2) { animation-delay: 0.2s; }
  .typing-dot:nth-child(3) { animation-delay: 0.4s; }
  @keyframes typingBounce {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
    30% { transform: translateY(-6px); opacity: 1; }
  }

  .chat-input-area {
    padding: 14px 16px;
    border-top: 1px solid rgba(244, 239, 227, 0.08);
  }
  .chat-input-wrapper {
    display: flex;
    align-items: flex-end;
    gap: 8px;
    background: rgba(244, 239, 227, 0.04);
    border: 1px solid rgba(244, 239, 227, 0.1);
    border-radius: 999px;
    padding: 6px 6px 6px 18px;
    position: relative;
    transition: border-color 0.3s;
  }
  .chat-input-wrapper:focus-within {
    border-color: var(--gold);
  }
  .chat-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    color: var(--cream);
    font-size: 14px;
    font-family: var(--font-sans);
    resize: none;
    max-height: 100px;
    line-height: 1.5;
    padding: 8px 0;
  }
  .chat-input::placeholder { color: rgba(244, 239, 227, 0.35); }

  .char-count {
    position: absolute;
    right: 52px;
    bottom: 14px;
    font-size: 10.5px;
    font-family: var(--font-mono);
  }

  .chat-send {
    width: 38px;
    height: 38px;
    border-radius: 999px;
    background: var(--gold);
    color: var(--ink);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: all 0.3s;
    -webkit-tap-highlight-color: transparent;
  }
  .chat-send:hover:not(:disabled) { transform: scale(1.05); background: var(--gold-soft); }
  .chat-send:disabled { opacity: 0.5; cursor: not-allowed; }

  .chat-limit {
    position: absolute;
    inset: 0;
    background: rgba(26, 22, 20, 0.95);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    text-align: center;
    z-index: 10;
    border-radius: 6px;
  }
  .chat-limit p {
    color: var(--cream);
    font-size: 15px;
    line-height: 1.6;
    max-width: 360px;
    font-family: var(--font-sans);
  }

  @media (prefers-reduced-motion: reduce) {
    .typing-dot { animation: none; opacity: 0.6; }
  }
</style>
