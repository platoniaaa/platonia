---
// Reusable bust animation that scrubs to scroll position. Works anywhere on
// the page (Hero, About, etc.) — the scroll formula derives from the
// element's own document offset, so a busto deep in the page only starts
// animating when it scrolls into view.
//
// Desktop (>=1024px): scrubbable <video> via currentTime.
// Mobile/tablet (<=1023px): <canvas> + drawImage with pre-decoded frames.
// Why canvas? On iOS Safari, swapping <img src> for a preloaded image still
// triggers a decode + element re-render that visibly lags during fast
// swipes. drawImage of an already-loaded HTMLImageElement is GPU-accelerated
// and frame-perfect.
---

<div class="busto-media-wrapper">
  <video
    class="busto-video busto-media"
    poster="/video/hero-busto-poster.jpg"
    muted
    playsinline
    webkit-playsinline="true"
    preload="none"
    disablepictureinpicture
    disableremoteplayback
    aria-hidden="true"
  >
    <source src="/video/hero-busto.mp4" type="video/mp4" />
  </video>
  <canvas class="busto-canvas busto-media" aria-hidden="true"></canvas>
  <!-- Fallback poster while frames are loading -->
  <img
    class="busto-fallback busto-media"
    src="/video/hero-busto-poster.jpg"
    alt="Platonia"
    aria-hidden="true"
    decoding="async"
  />
</div>

<style>
  .busto-media-wrapper {
    position: relative;
    width: 100%;
    max-width: 420px;
    aspect-ratio: 1 / 1;
    -webkit-mask-image: radial-gradient(ellipse at center, #000 50%, transparent 95%);
    mask-image: radial-gradient(ellipse at center, #000 50%, transparent 95%);
  }
  .busto-media {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    background: transparent;
  }
  .busto-canvas { display: none; }
  .busto-fallback { display: none; }

  @media (max-width: 1023px) {
    .busto-video { display: none; }
    .busto-canvas { display: block; }
    /* The fallback is only shown until the canvas has its first frame */
    .busto-fallback { display: block; }
    .busto-media-wrapper.is-ready .busto-fallback { display: none; }
  }
</style>

<script>
  const FRAME_COUNT = 40;
  const frameUrls: string[] = [];
  for (let i = 1; i <= FRAME_COUNT; i++) {
    frameUrls.push('/video/frames/f' + String(i).padStart(3, '0') + '.webp');
  }

  const isMobileLayout = window.matchMedia('(max-width: 1023px)').matches;

  // Preload all frames as a shared pool so multiple busto instances on the
  // same page (Hero + About would never co-exist, but the cache is still
  // shared anyway) only download once.
  const sharedImages: HTMLImageElement[] = new Array(FRAME_COUNT);
  let sharedImagesLoaded = 0;
  const loadCallbacks: Array<(idx: number) => void> = [];

  if (isMobileLayout) {
    frameUrls.forEach((url, idx) => {
      const img = new Image();
      img.decoding = 'async';
      img.onload = () => {
        sharedImages[idx] = img;
        sharedImagesLoaded++;
        loadCallbacks.forEach((cb) => cb(idx));
      };
      img.src = url;
    });
  }

  function initBusto(wrapper: Element) {
    const wrapperEl = wrapper as HTMLElement;
    const video = wrapper.querySelector('.busto-video') as HTMLVideoElement | null;
    const canvas = wrapper.querySelector('.busto-canvas') as HTMLCanvasElement | null;

    let ticking = false;

    function getProgress() {
      const rect = wrapperEl.getBoundingClientRect();
      const viewportH = window.innerHeight || 1;
      const wrapperTop = rect.top + window.scrollY;
      const blockHeight = rect.height || viewportH * 0.3;
      const entryScroll = Math.max(0, wrapperTop - viewportH);
      let completionScroll = Math.max(0, wrapperTop - viewportH * 0.2);
      const exitScroll = wrapperTop + blockHeight;
      const maxRange = Math.max(1, (exitScroll - entryScroll) * 0.65);
      const minRange = Math.min(viewportH * 0.3, maxRange);
      if (completionScroll - entryScroll < minRange) {
        completionScroll = entryScroll + minRange;
      }
      const range = Math.max(1, completionScroll - entryScroll);
      return Math.max(0, Math.min(1, (window.scrollY - entryScroll) / range));
    }

    function onScroll() {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(update);
      }
    }

    let update: () => void;

    // ============================================================
    // MOBILE: canvas + drawImage
    // ============================================================
    if (isMobileLayout && canvas) {
      const ctx = canvas.getContext('2d', { alpha: true });
      if (!ctx) return;

      let currentIdx = -1;

      function resizeCanvas() {
        const dpr = Math.min(window.devicePixelRatio || 1, 2);
        const w = wrapperEl.clientWidth || 320;
        const h = wrapperEl.clientHeight || 320;
        canvas!.width = Math.round(w * dpr);
        canvas!.height = Math.round(h * dpr);
        canvas!.style.width = '100%';
        canvas!.style.height = '100%';
        if (currentIdx >= 0) drawFrame(currentIdx);
      }

      function drawFrame(idx: number) {
        const img = sharedImages[idx];
        if (!img || !img.complete) return;
        const cw = canvas!.width;
        const ch = canvas!.height;
        const iw = img.naturalWidth;
        const ih = img.naturalHeight;
        // Object-fit cover: scale source to fill canvas, center, crop
        const iAspect = iw / ih;
        const cAspect = cw / ch;
        let sx = 0, sy = 0, sw = iw, sh = ih;
        if (iAspect > cAspect) {
          sw = ih * cAspect;
          sx = (iw - sw) / 2;
        } else {
          sh = iw / cAspect;
          sy = (ih - sh) / 2;
        }
        ctx!.clearRect(0, 0, cw, ch);
        ctx!.drawImage(img, sx, sy, sw, sh, 0, 0, cw, ch);
        wrapperEl.classList.add('is-ready');
      }

      update = function () {
        ticking = false;
        const progress = getProgress();
        const idx = Math.min(FRAME_COUNT - 1, Math.floor(progress * FRAME_COUNT));
        if (idx !== currentIdx) {
          currentIdx = idx;
          drawFrame(idx);
        }
      };

      // When a new frame finishes loading, redraw if it's the active one
      loadCallbacks.push((loadedIdx) => {
        if (loadedIdx === currentIdx) drawFrame(currentIdx);
        // Draw frame 0 as soon as it's ready, even before user scrolls
        if (loadedIdx === 0 && currentIdx < 0) {
          currentIdx = 0;
          drawFrame(0);
        }
      });

      resizeCanvas();
      window.addEventListener('resize', resizeCanvas, { passive: true });
      window.addEventListener('orientationchange', resizeCanvas, { passive: true });
      window.addEventListener('scroll', onScroll, { passive: true });
      requestAnimationFrame(update);
      return;
    }

    // ============================================================
    // DESKTOP: scrubbable <video>
    // ============================================================
    if (!video) return;
    video.preload = 'auto';
    try { video.load(); } catch (e) {}

    let duration = 0;
    let primed = false;

    function primeOnFirstGesture() {
      if (primed) return;
      primed = true;
      const tryPlay = video!.play();
      if (tryPlay && typeof tryPlay.then === 'function') {
        tryPlay.then(() => video!.pause()).catch(() => {});
      }
      update();
    }

    update = function () {
      ticking = false;
      if (!duration) return;
      const progress = getProgress();
      const target = duration * progress;
      if (Math.abs(video!.currentTime - target) > 0.02) {
        try {
          if (typeof (video as any).fastSeek === 'function') {
            (video as any).fastSeek(target);
          } else {
            video!.currentTime = target;
          }
        } catch (e) {}
      }
    };

    function onMetadataReady() {
      duration = video!.duration || 0;
      try { video!.currentTime = 0.01; } catch (e) {}
      update();
    }

    if (video.readyState >= 1 && video.duration) {
      onMetadataReady();
    } else {
      video.addEventListener('loadedmetadata', onMetadataReady, { once: true });
    }

    ['touchstart', 'touchend', 'click', 'scroll'].forEach((evt) => {
      window.addEventListener(evt, primeOnFirstGesture, { once: true, passive: true });
    });

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });

    requestAnimationFrame(update);
  }

  document.querySelectorAll('.busto-media-wrapper').forEach(initBusto);
</script>
