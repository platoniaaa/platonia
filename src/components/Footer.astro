---
import logoCompleto from '../assets/img/logo-completo.png';

const links = [
  { label: 'Servicios', href: '#servicios' },
  { label: 'Productos', href: '#productos' },
  { label: '¿Por qué Platonia?', href: '#por-que-platonia' },
  { label: 'Sobre Nosotros', href: '#nosotros' },
  { label: 'Contacto', href: '#contacto' },
];

const year = new Date().getFullYear();
---

<footer class="relative pt-12 md:pt-20 pb-8 overflow-hidden" style="background-color: var(--clr-dark);">
  <!-- Noise texture -->
  <div class="absolute inset-0 noise-bg"></div>

  <div class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-16 pb-10 md:pb-14 border-b border-white/8">
      <!-- Logo & description -->
      <div class="md:col-span-1">
        <img src={logoCompleto.src} alt="Platonia" class="h-10 w-auto mb-5 brightness-0 invert" />
        <p class="text-white/40 text-sm leading-relaxed max-w-xs">
          Startup tecnol&oacute;gica chilena especializada en soluciones digitales inteligentes para pymes: presencia digital, automatizaci&oacute;n con IA, sistemas de gesti&oacute;n y desarrollo a medida.
        </p>
      </div>

      <!-- Quick links -->
      <div>
        <h4 class="font-bold text-white mb-5 text-sm tracking-wide uppercase" style="font-family: var(--font-heading);">Enlaces r&aacute;pidos</h4>
        <ul class="space-y-3">
          {links.map(link => (
            <li>
              <a href={link.href} class="text-white/40 hover:text-primary-light transition-colors text-sm">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="font-bold text-white mb-5 text-sm tracking-wide uppercase" style="font-family: var(--font-heading);">Contacto</h4>
        <ul class="space-y-3 text-sm text-white/40">
          <li class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-primary-light/60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            contacto@platonia.cl
          </li>
          <li class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-primary-light/60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            +56 9 9707 6130
          </li>
          <li class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-primary-light/60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            Santiago, Chile
          </li>
        </ul>

        <!-- Social icons -->
        <div class="flex gap-3 mt-7">
          <a href="#" class="w-9 h-9 bg-white/5 border border-white/10 hover:bg-primary hover:border-primary rounded-lg flex items-center justify-center transition-all duration-300" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-white/50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
          <a href="#" class="w-9 h-9 bg-white/5 border border-white/10 hover:bg-primary hover:border-primary rounded-lg flex items-center justify-center transition-all duration-300" aria-label="LinkedIn">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-white/50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
          </a>
          <a href="https://wa.me/56997076130" target="_blank" rel="noopener noreferrer" class="w-9 h-9 bg-white/5 border border-white/10 hover:bg-primary hover:border-primary rounded-lg flex items-center justify-center transition-all duration-300" aria-label="WhatsApp">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-white/50" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Copyright -->
    <div class="pt-8 text-center">
      <p class="text-white/25 text-xs font-mono-accent">
        &copy; {year} Platonia. Todos los derechos reservados.
      </p>
    </div>
  </div>
</footer>
