---
---

<section class="relative py-20 md:py-28 overflow-hidden" style="background:var(--ink);color:var(--cream);">
  <div class="absolute inset-0 noise-bg"></div>

  <div class="max-w-[1440px] mx-auto px-6 md:px-10 relative z-10">
    <div class="grid grid-cols-12 gap-4 md:gap-8 items-end">
      <div class="col-span-12 md:col-span-7">
        <div class="eyebrow mb-6" style="color:var(--gold);">
          <span class="eyebrow-dot">Conversemos</span>
        </div>
        <h3 class="display-lg" style="color:var(--cream);">
          &iquest;Listo para dar el salto <span class="italic-accent" style="color:var(--gold);">digital?</span>
        </h3>
      </div>

      <div class="col-span-12 md:col-span-5 md:pb-3">
        <p class="text-base md:text-lg leading-relaxed mb-6" style="color:rgba(244,239,227,0.7);">
          Cu&eacute;ntanos tu desaf&iacute;o y te mostramos c&oacute;mo resolverlo. Una reuni&oacute;n de diagn&oacute;stico sin costo.
        </p>
        <a href="#contacto" class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full transition-all" style="background:var(--cream);color:var(--ink);">
          <span class="font-medium text-sm">Agendar conversaci&oacute;n</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>
