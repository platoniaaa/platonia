---
---

<section id="hero" class="relative min-h-[100svh] flex items-center overflow-hidden" style="background:var(--night);">

  <!-- Violet aurora mesh background -->
  <div class="absolute inset-0 violet-mesh"></div>

  <!-- Decorative glowing orbs -->
  <div class="orb w-[500px] h-[500px] top-[10%] right-[-10%] hidden md:block" style="background:radial-gradient(circle, rgba(168,85,247,0.5) 0%, transparent 60%);"></div>
  <div class="orb w-[400px] h-[400px] bottom-[10%] left-[-15%] hidden md:block" style="background:radial-gradient(circle, rgba(107,33,168,0.6) 0%, transparent 60%);animation-delay:-4s;"></div>
  <div class="orb w-[280px] h-[280px] top-[40%] left-[40%]" style="background:radial-gradient(circle, rgba(229,192,106,0.2) 0%, transparent 70%);animation-delay:-2s;"></div>

  <!-- Noise overlay -->
  <div class="absolute inset-0 noise-bg"></div>

  <!-- Grid lines decoration -->
  <div class="absolute inset-0 pointer-events-none hidden md:block" style="background-image: linear-gradient(rgba(216,180,254,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(216,180,254,0.04) 1px, transparent 1px); background-size: 80px 80px;"></div>

  <div class="relative z-10 w-full max-w-[1440px] mx-auto px-6 md:px-10 pt-24 md:pt-32 pb-16 md:pb-20">

    <!-- Top label + hairline -->
    <div class="hero-reveal hero-reveal-1 flex items-center gap-4 mb-10 md:mb-16">
      <span class="eyebrow eyebrow-dot" style="color:var(--lilac);">Startup tecnol&oacute;gica chilena</span>
      <div class="hairline flex-1 max-w-[200px]"></div>
    </div>

    <!-- Headline -->
    <h1 class="hero-reveal hero-reveal-2 display-xl mb-8 md:mb-10 max-w-5xl">
      Tecnolog&iacute;a
      <span class="italic-accent">inteligente,</span>
      <br />
      a precios de pyme.
    </h1>

    <!-- Sub + CTAs -->
    <div class="grid grid-cols-12 gap-6 md:gap-10 items-end mb-14 md:mb-20">
      <div class="col-span-12 md:col-span-6">
        <p class="hero-reveal hero-reveal-3 text-lg md:text-xl leading-relaxed max-w-xl" style="color:var(--text-muted);">
          Dise&ntilde;amos p&aacute;ginas web, automatizamos procesos con IA y construimos plataformas digitales a medida para pymes.
        </p>
      </div>

      <div class="hero-reveal hero-reveal-4 col-span-12 md:col-span-6">
        <div class="flex flex-col sm:flex-row gap-3 md:justify-end">
          <a href="#contacto" class="btn-primary">
            Cotiza tu proyecto
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
          <a href="#servicios" class="btn-secondary">Ver servicios</a>
        </div>
      </div>
    </div>

    <!-- Stats bar -->
    <div class="hero-reveal hero-reveal-5 pt-8 md:pt-10 border-t" style="border-color:rgba(216,180,254,0.15);">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-10">
        <div>
          <div class="font-display text-3xl md:text-5xl font-medium mb-1" style="color:var(--cream);letter-spacing:-0.03em;">20<span style="color:var(--lilac);">+</span></div>
          <div class="marginalia uppercase tracking-wider" style="color:var(--text-muted);">Proyectos</div>
        </div>
        <div>
          <div class="font-display text-3xl md:text-5xl font-medium mb-1" style="color:var(--cream);letter-spacing:-0.03em;">5<span style="color:var(--lilac);">+</span></div>
          <div class="marginalia uppercase tracking-wider" style="color:var(--text-muted);">A&ntilde;os</div>
        </div>
        <div>
          <div class="font-display text-3xl md:text-5xl font-medium mb-1" style="color:var(--cream);letter-spacing:-0.03em;">50<span style="color:var(--lilac);">+</span></div>
          <div class="marginalia uppercase tracking-wider" style="color:var(--text-muted);">Procesos</div>
        </div>
        <div>
          <div class="font-display text-3xl md:text-5xl font-medium mb-1" style="color:var(--cream);letter-spacing:-0.03em;">100<span style="color:var(--lilac);">%</span></div>
          <div class="marginalia uppercase tracking-wider" style="color:var(--text-muted);">Satisf.</div>
        </div>
      </div>
    </div>
  </div>
</section>
