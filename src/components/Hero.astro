---
---

<section id="hero" class="relative min-h-[100svh] flex items-center overflow-hidden pt-20 pb-20 md:pt-0 md:pb-0" style="background-color: var(--clr-dark);">
  <!-- Gradient mesh background -->
  <div class="absolute inset-0 gradient-mesh"></div>
  <!-- Noise texture -->
  <div class="absolute inset-0 noise-bg"></div>
  <!-- Decorative elements (hidden on small mobile to avoid clutter) -->
  <div class="hidden sm:block absolute top-1/4 right-[10%] w-64 h-64 rounded-full border border-primary-light/10" style="animation: float 6s ease-in-out infinite;"></div>
  <div class="hidden sm:block absolute bottom-1/3 left-[5%] w-32 h-32 rounded-full border border-primary/10" style="animation: float 8s ease-in-out infinite 2s;"></div>

  <div class="max-w-[1280px] mx-auto px-5 sm:px-6 lg:px-8 relative z-10 w-full">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Text Content -->
      <div class="max-w-2xl text-center sm:text-left mx-auto sm:mx-0">
        <span class="hero-reveal hero-reveal-1 inline-block font-mono-accent text-primary-light/90 text-[11px] sm:text-sm tracking-widest uppercase mb-5 md:mb-8">
          Startup tecnol&oacute;gica chilena
        </span>
        <h1 class="hero-reveal hero-reveal-2 text-[1.75rem] sm:text-4xl md:text-5xl lg:text-[3.5rem] xl:text-6xl font-bold text-white leading-[1.15] mb-5 md:mb-7 tracking-tight" style="font-family: var(--font-heading);">
          Transformamos tu negocio con
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-light via-primary to-primary-light" style="background-size: 200% auto; animation: shimmerGradient 4s linear infinite;">
            tecnolog&iacute;a inteligente
          </span>
        </h1>
        <p class="hero-reveal hero-reveal-3 text-[0.95rem] md:text-lg lg:text-xl text-white/60 mb-7 md:mb-10 max-w-xl leading-relaxed mx-auto sm:mx-0">
          Dise&ntilde;amos p&aacute;ginas web, automatizamos procesos y construimos plataformas digitales a medida. Tecnolog&iacute;a de primer nivel a precios de pyme.
        </p>
        <div class="hero-reveal hero-reveal-4 flex flex-col sm:flex-row gap-3 sm:gap-4">
          <a href="#contacto" class="btn-primary text-[0.95rem] md:text-lg !py-3.5 md:!py-4 !px-7 md:!px-9 w-full sm:w-auto text-center touch-manipulation">
            Cotiza tu proyecto gratis
          </a>
          <a href="#servicios" class="btn-secondary !border-white/20 !text-white/80 hover:!bg-white/10 hover:!text-white hover:!border-white/30 text-[0.95rem] md:text-lg !py-3.5 md:!py-4 !px-7 md:!px-9 w-full sm:w-auto text-center touch-manipulation">
            Conoce nuestros servicios &darr;
          </a>
        </div>
      </div>

      <!-- Visual Element - Abstract tech visualization (desktop only) -->
      <div class="hero-reveal hero-reveal-5 hidden lg:flex items-center justify-center">
        <div class="relative w-full max-w-md">
          <div class="relative bg-white/5 backdrop-blur-sm rounded-2xl border border-white/10 p-6 shadow-purple-lg">
            <div class="flex items-center gap-2 mb-6">
              <div class="w-2.5 h-2.5 rounded-full bg-primary-light/60"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-primary/40"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-white/20"></div>
              <div class="flex-1 mx-3">
                <div class="h-5 bg-white/5 rounded-md border border-white/10 flex items-center px-3">
                  <span class="font-mono-accent text-[10px] text-white/30">platonia.cl</span>
                </div>
              </div>
            </div>
            <div class="space-y-4">
              <div class="h-5 bg-gradient-to-r from-primary/30 to-primary-light/20 rounded w-3/4"></div>
              <div class="h-3 bg-white/8 rounded w-full"></div>
              <div class="h-3 bg-white/6 rounded w-5/6"></div>
              <div class="grid grid-cols-3 gap-3 mt-6">
                <div class="h-20 bg-gradient-to-br from-primary/15 to-primary-light/10 rounded-lg border border-white/5"></div>
                <div class="h-20 bg-gradient-to-br from-primary/10 to-primary-light/15 rounded-lg border border-white/5"></div>
                <div class="h-20 bg-gradient-to-br from-primary-light/10 to-primary/15 rounded-lg border border-white/5"></div>
              </div>
              <div class="flex gap-3 mt-4">
                <div class="h-9 bg-gradient-to-r from-primary to-primary-light rounded-md w-28"></div>
                <div class="h-9 border border-white/15 rounded-md w-28"></div>
              </div>
            </div>
          </div>
          <div class="absolute -top-3 -right-3 bg-gradient-to-br from-primary to-primary-light text-white px-4 py-2 rounded-xl shadow-purple-lg text-xs font-bold font-mono-accent" style="animation: float 4s ease-in-out infinite;">
            SEO &check;
          </div>
          <div class="absolute -bottom-3 -left-3 bg-white/10 backdrop-blur-md text-white px-4 py-2 rounded-xl border border-white/20 text-xs font-bold font-mono-accent" style="animation: float 5s ease-in-out infinite 1.5s;">
            Mobile First
          </div>
          <div class="absolute top-1/2 -right-6 bg-white/10 backdrop-blur-md text-primary-light px-3 py-1.5 rounded-lg border border-white/10 text-[10px] font-bold font-mono-accent" style="animation: float 6s ease-in-out infinite 0.8s;">
            IA Integrada
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Wave divider -->
  <div class="section-divider-wave">
    <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
      <path d="M0,60 L0,20 Q360,0 720,30 Q1080,60 1440,20 L1440,60 Z" fill="var(--clr-cream)"/>
    </svg>
  </div>
</section>

<style>
  @keyframes shimmerGradient {
    0% { background-position: -200% center; }
    100% { background-position: 200% center; }
  }
</style>
