---
import BustoVideo from './BustoVideo.astro';
---

<section id="hero" class="relative min-h-[100svh] overflow-hidden" style="background:var(--night);">

  <!-- Violet aurora mesh background -->
  <div class="absolute inset-0 violet-mesh"></div>

  <!-- Decorative glowing orbs -->
  <div class="orb w-[500px] h-[500px] top-[10%] right-[-10%] hidden md:block" style="background:radial-gradient(circle, rgba(168,85,247,0.5) 0%, transparent 60%);"></div>
  <div class="orb w-[400px] h-[400px] bottom-[10%] left-[-15%] hidden md:block" style="background:radial-gradient(circle, rgba(107,33,168,0.6) 0%, transparent 60%);animation-delay:-4s;"></div>
  <div class="orb w-[280px] h-[280px] top-[40%] left-[40%]" style="background:radial-gradient(circle, rgba(229,192,106,0.2) 0%, transparent 70%);animation-delay:-2s;"></div>

  <!-- Noise overlay -->
  <div class="absolute inset-0 noise-bg"></div>

  <div class="hero-inner relative z-10 w-full max-w-[1440px] mx-auto px-6 md:px-10">

    <!-- Headline + video -->
    <div class="hero-headline-row relative">
      <div class="hero-headline-cell">
        <h1 class="hero-reveal hero-reveal-2 hero-headline">
          Tecnolog&iacute;a<br class="break-mobile" />
          <span class="italic-accent">inteligente,</span><br />
          a precios<br class="break-mobile" />
          de pyme.
        </h1>
      </div>

      <div class="hero-video-block hero-reveal hero-reveal-2">
        <BustoVideo />
      </div>
    </div>

    <!-- Sub + CTAs -->
    <div class="hero-cta-row grid grid-cols-12 gap-6 md:gap-10 items-end">
      <div class="col-span-12 md:col-span-6">
        <p class="hero-reveal hero-reveal-3 text-lg md:text-xl leading-relaxed max-w-xl" style="color:var(--text-muted);">
          Dise&ntilde;amos p&aacute;ginas web, automatizamos procesos con IA y construimos plataformas digitales a medida para pymes.
        </p>
      </div>

      <div class="hero-reveal hero-reveal-4 col-span-12 md:col-span-6">
        <div class="flex flex-col sm:flex-row gap-3 md:justify-end">
          <a href="/nosotros" class="btn-primary">
            Nosotros
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </div>
    </div>

  </div>

  <style>
    /* Fill the viewport vertically and distribute content top -> bottom */
    .hero-inner {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      min-height: 100svh;
      padding-top: 6rem;
      padding-bottom: 2.5rem;
    }
    @media (min-width: 768px) {
      .hero-inner {
        padding-top: 8rem;
        padding-bottom: 5rem;
      }
    }

    /* Top block (headline + video). Min-height lets it grow to its content
       while the CTA gets pushed to the bottom by flex justify-between. */
    .hero-headline-row {
      width: 100%;
    }

    /* Headline scale (a bit larger min size on phones so it feels prominent) */
    .hero-headline {
      font-family: var(--font-display);
      font-weight: 500;
      font-size: clamp(3rem, 11vw, 7rem);
      line-height: 0.95;
      letter-spacing: -0.04em;
      color: var(--cream);
    }
    .hero-headline-cell {
      position: relative;
      z-index: 2;
    }
    /* Forces 4-line wrap on phones/tablets */
    .break-mobile { display: none; }
    @media (max-width: 1023px) {
      .break-mobile { display: inline; }
    }
    @media (max-width: 640px) {
      .hero-headline {
        letter-spacing: -0.035em;
      }
    }

    /* Video sits absolutely on mobile so it isn't squashed by a grid column.
       On desktop we switch to a grid-based layout where it sits in col 8-12. */
    .hero-video-block {
      position: absolute;
      top: 0;
      right: 0;
      width: 50%;
      max-width: 240px;
      z-index: 1;
    }
    @media (max-width: 640px) {
      .hero-video-block {
        width: 52%;
        max-width: 220px;
      }
    }
    @media (min-width: 1024px) {
      .hero-headline-row {
        display: grid;
        grid-template-columns: 7fr 5fr;
        gap: 2.5rem;
        align-items: center;
      }
      .hero-video-block {
        position: static;
        width: 100%;
        max-width: 420px;
        justify-self: end;
        margin-left: auto;
      }
    }

    /* CTA row sits at the bottom — keep its own spacing tight */
    .hero-cta-row { width: 100%; }
  </style>
</section>
