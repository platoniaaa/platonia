---
---

<section id="hero" class="relative min-h-[100svh] flex items-center overflow-hidden" style="background:var(--night);">

  <!-- Violet aurora mesh background -->
  <div class="absolute inset-0 violet-mesh"></div>

  <!-- Decorative glowing orbs -->
  <div class="orb w-[500px] h-[500px] top-[10%] right-[-10%] hidden md:block" style="background:radial-gradient(circle, rgba(168,85,247,0.5) 0%, transparent 60%);"></div>
  <div class="orb w-[400px] h-[400px] bottom-[10%] left-[-15%] hidden md:block" style="background:radial-gradient(circle, rgba(107,33,168,0.6) 0%, transparent 60%);animation-delay:-4s;"></div>
  <div class="orb w-[280px] h-[280px] top-[40%] left-[40%]" style="background:radial-gradient(circle, rgba(229,192,106,0.2) 0%, transparent 70%);animation-delay:-2s;"></div>

  <!-- Noise overlay -->
  <div class="absolute inset-0 noise-bg"></div>

  <!-- Grid lines decoration -->
  <div class="absolute inset-0 pointer-events-none hidden md:block" style="background-image: linear-gradient(rgba(216,180,254,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(216,180,254,0.04) 1px, transparent 1px); background-size: 80px 80px;"></div>

  <div class="relative z-10 w-full max-w-[1440px] mx-auto px-6 md:px-10 pt-24 md:pt-32 pb-16 md:pb-20">

    <!-- Top label + hairline -->
    <div class="hero-reveal hero-reveal-1 flex items-center gap-4 mb-10 md:mb-16">
      <span class="eyebrow eyebrow-dot" style="color:var(--lilac);">Startup tecnol&oacute;gica chilena</span>
      <div class="hairline flex-1 max-w-[200px]"></div>
    </div>

    <!-- Headline + video grid -->
    <div class="hero-headline-row grid grid-cols-12 gap-3 md:gap-8 lg:gap-10 items-center mb-8 md:mb-10">
      <!-- TEXT (left, can overflow over video on mobile) -->
      <div class="col-span-7 lg:col-span-7 hero-headline-cell">
        <h1 class="hero-reveal hero-reveal-2 hero-headline">
          Tecnolog&iacute;a<br class="break-mobile" />
          <span class="italic-accent">inteligente,</span><br />
          a precios<br class="break-mobile" />
          de pyme.
        </h1>
      </div>

      <!-- VIDEO (right on all sizes) -->
      <div class="hero-reveal hero-reveal-2 col-span-5 lg:col-span-5 flex justify-end">
        <div class="hero-video-wrapper">
          <!-- Desktop: scrubbable video (preload="none" so it never loads on mobile) -->
          <video
            id="hero-video"
            class="hero-video hero-media"
            poster="/video/hero-busto-poster.jpg"
            muted
            playsinline
            webkit-playsinline="true"
            preload="none"
            disablepictureinpicture
            disableremoteplayback
            aria-hidden="true"
          >
            <source src="/video/hero-busto.mp4" type="video/mp4" />
          </video>
          <!-- Mobile: image sequence (40 WebP frames). Browser only fetches
               them when this <img> is actually visible, which we control via
               CSS so desktop doesn't pay the cost. -->
          <img
            id="hero-frames"
            class="hero-frames hero-media"
            src="/video/hero-busto-poster.jpg"
            alt="Platonia"
            aria-hidden="true"
            decoding="async"
            fetchpriority="high"
          />
        </div>
      </div>
    </div>

    <!-- Sub + CTAs -->
    <div class="grid grid-cols-12 gap-6 md:gap-10 items-end mb-14 md:mb-20">
      <div class="col-span-12 md:col-span-6">
        <p class="hero-reveal hero-reveal-3 text-lg md:text-xl leading-relaxed max-w-xl" style="color:var(--text-muted);">
          Dise&ntilde;amos p&aacute;ginas web, automatizamos procesos con IA y construimos plataformas digitales a medida para pymes.
        </p>
      </div>

      <div class="hero-reveal hero-reveal-4 col-span-12 md:col-span-6">
        <div class="flex flex-col sm:flex-row gap-3 md:justify-end">
          <a href="/nosotros" class="btn-primary">
            Nosotros
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </div>
    </div>

  </div>

  <style>
    .hero-video-wrapper {
      position: relative;
      width: 100%;
      max-width: 420px;
      aspect-ratio: 1 / 1;
      /* Feather the edges so the bust blends into the violet background */
      -webkit-mask-image: radial-gradient(ellipse at center, #000 50%, transparent 95%);
      mask-image: radial-gradient(ellipse at center, #000 50%, transparent 95%);
    }
    .hero-media {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      background: transparent;
    }
    /* Default: show the video, hide the frame image (desktop). */
    .hero-frames { display: none; }
    @media (max-width: 1023px) {
      /* Mobile/tablet: swap to the image sequence (more reliable scrubbing). */
      .hero-video { display: none; }
      .hero-frames { display: block; }
    }

    /* Headline uses the same large display-xl scale on all sizes. */
    .hero-headline {
      font-family: var(--font-display);
      font-weight: 500;
      font-size: clamp(2.75rem, 9vw, 7rem);
      line-height: 0.95;
      letter-spacing: -0.04em;
      color: var(--cream);
    }
    .hero-headline-cell {
      position: relative;
      z-index: 2;
    }
    /* Extra line breaks only on phones/tablets (forces 4-line wrap) */
    .break-mobile { display: none; }
    @media (max-width: 1023px) {
      .break-mobile { display: inline; }
      .hero-video-wrapper { max-width: 260px; }
    }
    @media (max-width: 640px) {
      .hero-video-wrapper { max-width: 200px; }
      .hero-headline {
        letter-spacing: -0.035em;
      }
    }
  </style>

  <script is:inline>
    (function () {
      const video = document.getElementById('hero-video');
      const framesImg = document.getElementById('hero-frames');
      const videoWrap = video ? video.closest('.hero-video-wrapper') : null;
      if (!videoWrap) return;

      const isMobileLayout = window.matchMedia('(max-width: 1023px)').matches;

      let ticking = false;

      function computeProgress() {
        const rect = videoWrap.getBoundingClientRect();
        const initialTop = rect.top + window.scrollY;
        const scrolled = window.scrollY;
        const range = Math.max(1, initialTop * 0.6);
        return Math.max(0, Math.min(1, scrolled / range));
      }

      function onScroll() {
        if (!ticking) {
          ticking = true;
          requestAnimationFrame(update);
        }
      }

      // ----------------------------------------------------------------
      // MOBILE: image-sequence scrubbing (40 WebP frames)
      // ----------------------------------------------------------------
      if (isMobileLayout && framesImg) {
        const FRAME_COUNT = 40;
        const frameUrls = [];
        for (let i = 1; i <= FRAME_COUNT; i++) {
          frameUrls.push('/video/frames/f' + String(i).padStart(3, '0') + '.webp');
        }

        // Preload every frame so swapping is instant
        const preloaded = new Array(FRAME_COUNT);
        let loadedCount = 0;
        frameUrls.forEach((url, i) => {
          const img = new Image();
          img.decoding = 'async';
          img.onload = () => {
            loadedCount++;
            if (loadedCount === FRAME_COUNT) update();
          };
          img.src = url;
          preloaded[i] = img;
        });

        // Show first frame immediately
        framesImg.src = frameUrls[0];

        let currentIdx = -1;
        var update = function () {
          ticking = false;
          const progress = computeProgress();
          const idx = Math.min(FRAME_COUNT - 1, Math.floor(progress * FRAME_COUNT));
          if (idx !== currentIdx) {
            currentIdx = idx;
            framesImg.src = frameUrls[idx];
          }
        };

        window.addEventListener('scroll', onScroll, { passive: true });
        window.addEventListener('resize', onScroll, { passive: true });
        window.addEventListener('orientationchange', onScroll, { passive: true });
        requestAnimationFrame(update);
        return;
      }

      // ----------------------------------------------------------------
      // DESKTOP: scrubbable <video>
      // ----------------------------------------------------------------
      if (!video) return;
      // Force the video to start loading even though preload was "none"
      video.preload = 'auto';
      try { video.load(); } catch (e) {}

      let duration = 0;
      let primed = false;

      function primeOnFirstGesture() {
        if (primed) return;
        primed = true;
        const tryPlay = video.play();
        if (tryPlay && typeof tryPlay.then === 'function') {
          tryPlay.then(() => video.pause()).catch(() => {});
        }
        update();
      }

      var update = function () {
        ticking = false;
        if (!duration) return;
        const progress = computeProgress();
        const target = duration * progress;
        if (Math.abs(video.currentTime - target) > 0.02) {
          try {
            if (typeof video.fastSeek === 'function') {
              video.fastSeek(target);
            } else {
              video.currentTime = target;
            }
          } catch (e) {}
        }
      };

      function onMetadataReady() {
        duration = video.duration || 0;
        try { video.currentTime = 0.01; } catch (e) {}
        update();
      }

      if (video.readyState >= 1 && video.duration) {
        onMetadataReady();
      } else {
        video.addEventListener('loadedmetadata', onMetadataReady, { once: true });
      }

      ['touchstart', 'touchend', 'click', 'scroll'].forEach((evt) => {
        window.addEventListener(evt, primeOnFirstGesture, { once: true, passive: true });
      });

      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll, { passive: true });

      requestAnimationFrame(update);
    })();
  </script>
</section>
