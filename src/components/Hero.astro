---
---

<section id="hero" class="relative min-h-[100svh] flex flex-col justify-end overflow-hidden paper-grain" style="background:var(--cream);padding-top:6rem;padding-bottom:4rem;">

  <!-- Top marginalia bar -->
  <div class="absolute top-24 md:top-28 left-0 right-0 z-10 pointer-events-none">
    <div class="max-w-[1440px] mx-auto px-6 md:px-10 flex justify-between items-start">
      <div class="marginalia leading-snug max-w-[180px]">
        <div>Est. 2026</div>
        <div class="mt-1">Santiago &mdash;</div>
        <div>Chile</div>
      </div>
      <div class="hidden md:block marginalia leading-snug text-right max-w-[200px]">
        <div>Volumen I</div>
        <div class="mt-1">Plat&oacute;n + IA</div>
        <div>&mdash; una idea antigua</div>
      </div>
    </div>
  </div>

  <div class="relative z-10 w-full max-w-[1440px] mx-auto px-6 md:px-10">

    <!-- Chapter number + eyebrow -->
    <div class="hero-reveal hero-reveal-1 flex items-end gap-4 md:gap-8 mb-8 md:mb-12">
      <span class="chapter-num">01</span>
      <div class="pb-2 md:pb-4">
        <div class="eyebrow eyebrow-dot">Startup tecnol&oacute;gica</div>
        <div class="hairline w-24 mt-3"></div>
      </div>
    </div>

    <!-- Main headline - editorial asymmetric composition -->
    <div class="grid grid-cols-12 gap-4 md:gap-8 items-end mb-10 md:mb-14">
      <div class="col-span-12 lg:col-span-9">
        <h1 class="hero-reveal hero-reveal-2 display-xl" style="color:var(--ink);">
          Tecnolog&iacute;a inteligente,
          <br />
          <span class="italic-accent">a precios</span> de pyme.
        </h1>
      </div>

      <div class="hero-reveal hero-reveal-3 col-span-12 lg:col-span-3 lg:pb-4">
        <p class="text-[0.95rem] md:text-base leading-relaxed" style="color:var(--ash);">
          Dise&ntilde;amos p&aacute;ginas web, automatizamos procesos con IA y construimos plataformas digitales a medida para pymes.
        </p>
      </div>
    </div>

    <!-- CTAs + marginalia -->
    <div class="hero-reveal hero-reveal-4 grid grid-cols-12 gap-4 md:gap-8 items-center">
      <div class="col-span-12 md:col-span-8 flex flex-col sm:flex-row gap-3">
        <a href="#contacto" class="btn-primary">
          Cotiza tu proyecto
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a href="#servicios" class="btn-secondary">Ver servicios</a>
      </div>

      <div class="hidden md:flex col-span-4 justify-end">
        <div class="marginalia text-right">
          <div>&darr; Hacer scroll para leer</div>
          <div class="mt-1" style="color:var(--ink-soft);font-weight:500;">
            Un manifiesto en 9 cap&iacute;tulos
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom marquee line -->
    <div class="hero-reveal hero-reveal-5 mt-14 md:mt-24 pt-6 relative">
      <div class="hairline absolute top-0 left-0 right-0"></div>
      <div class="flex items-baseline justify-between flex-wrap gap-y-3">
        <div class="flex items-baseline gap-3">
          <span class="font-mono-accent text-2xl md:text-3xl font-medium" style="color:var(--ink);">20+</span>
          <span class="eyebrow">Proyectos</span>
        </div>
        <div class="flex items-baseline gap-3">
          <span class="font-mono-accent text-2xl md:text-3xl font-medium" style="color:var(--ink);">5+</span>
          <span class="eyebrow">A&ntilde;os</span>
        </div>
        <div class="flex items-baseline gap-3">
          <span class="font-mono-accent text-2xl md:text-3xl font-medium" style="color:var(--ink);">50+</span>
          <span class="eyebrow">Procesos</span>
        </div>
        <div class="flex items-baseline gap-3">
          <span class="font-mono-accent text-2xl md:text-3xl font-medium" style="color:var(--ink);">100%</span>
          <span class="eyebrow">Satisfecci&oacute;n</span>
        </div>
      </div>
    </div>
  </div>
</section>
