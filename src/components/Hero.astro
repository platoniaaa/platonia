---
import BustoVideo from './BustoVideo.astro';
---

<section id="hero" class="relative min-h-[100svh] overflow-hidden" style="background:var(--night);">

  <!-- Violet aurora mesh background -->
  <div class="absolute inset-0 violet-mesh"></div>

  <!-- Decorative glowing orbs -->
  <div class="orb w-[500px] h-[500px] top-[10%] right-[-10%] hidden md:block" style="background:radial-gradient(circle, rgba(168,85,247,0.5) 0%, transparent 60%);"></div>
  <div class="orb w-[400px] h-[400px] bottom-[10%] left-[-15%] hidden md:block" style="background:radial-gradient(circle, rgba(107,33,168,0.6) 0%, transparent 60%);animation-delay:-4s;"></div>
  <div class="orb w-[280px] h-[280px] top-[40%] left-[40%]" style="background:radial-gradient(circle, rgba(229,192,106,0.2) 0%, transparent 70%);animation-delay:-2s;"></div>

  <!-- Noise overlay -->
  <div class="absolute inset-0 noise-bg"></div>

  <div class="hero-inner relative z-10 w-full max-w-[1440px] mx-auto px-6 md:px-10">

    <!-- Eyebrow (mobile/tablet only) -->
    <div class="hero-eyebrow-mobile hero-reveal hero-reveal-1">Tecnolog&iacute;a para pymes</div>

    <!-- Headline + busto -->
    <div class="hero-headline-row">
      <div class="hero-headline-cell">
        <h1 class="hero-reveal hero-reveal-2 hero-headline">
          Tecnolog&iacute;a<br class="break-mobile" />
          <span class="italic-accent">inteligente,</span><br />
          a precios<br class="break-mobile" />
          de pyme.
        </h1>
      </div>

      <div class="hero-video-block hero-reveal hero-reveal-2">
        <BustoVideo />
      </div>
    </div>

    <!-- Description + CTA -->
    <div class="hero-bottom-row">
      <p class="hero-description hero-reveal hero-reveal-3">
        Dise&ntilde;amos p&aacute;ginas web, automatizamos procesos con IA y construimos plataformas digitales a medida para pymes.
      </p>
      <div class="hero-cta-row hero-reveal hero-reveal-4">
        <a href="/nosotros" class="btn-primary hero-cta">
          Nosotros
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>

  </div>

  <style>
    /* ===== Container fills viewport, distributes content ===== */
    .hero-inner {
      display: flex;
      flex-direction: column;
      min-height: 100svh;
      padding-top: 4.5rem;
      padding-bottom: 2rem;
      gap: 1.5rem;
    }
    @media (min-width: 768px) {
      .hero-inner {
        padding-top: 8rem;
        padding-bottom: 5rem;
        gap: 2rem;
        justify-content: space-between;
      }
    }

    /* ===== Mobile eyebrow ===== */
    .hero-eyebrow-mobile {
      color: var(--lilac);
      font-family: var(--font-mono, ui-monospace, monospace);
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.22em;
      text-transform: uppercase;
    }
    @media (min-width: 1024px) {
      .hero-eyebrow-mobile { display: none; }
    }

    /* ===== Headline scale ===== */
    .hero-headline {
      font-family: var(--font-display);
      font-weight: 500;
      font-size: clamp(3rem, 11vw, 7rem);
      line-height: 0.95;
      letter-spacing: -0.04em;
      color: var(--cream);
    }
    .hero-headline-cell {
      position: relative;
      z-index: 2;
    }
    /* Forces 4-line wrap on phones/tablets */
    .break-mobile { display: none; }
    @media (max-width: 1023px) {
      .break-mobile { display: inline; }
    }
    @media (max-width: 640px) {
      .hero-headline { letter-spacing: -0.035em; }
    }

    /* ===== Headline + Busto layout =====
       Mobile: stacked, big centered busto with rounded frame + glow
       Desktop: grid 7+5 with busto floating right (radial mask preserved) */
    .hero-headline-row {
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }
    .hero-video-block {
      display: flex;
      justify-content: center;
      width: 100%;
    }
    @media (max-width: 1023px) {
      /* Override BustoVideo's radial mask with a rounded card + glow */
      .hero-video-block :global(.busto-media-wrapper) {
        max-width: 460px;
        width: 100%;
        -webkit-mask-image: none;
        mask-image: none;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 25px 70px rgba(107, 33, 168, 0.45);
      }
    }
    @media (min-width: 1024px) {
      .hero-headline-row {
        display: grid;
        grid-template-columns: 7fr 5fr;
        gap: 2.5rem;
        align-items: center;
      }
      .hero-video-block :global(.busto-media-wrapper) {
        max-width: 420px;
        margin-left: auto;
      }
    }

    /* ===== Description + CTA ===== */
    .hero-bottom-row {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }
    .hero-description {
      font-size: 1rem;
      line-height: 1.6;
      color: var(--text-muted);
      max-width: 32rem;
    }
    .hero-cta-row { display: flex; }
    .hero-cta {
      width: 100%;
      justify-content: center;
      padding: 1.1rem 2rem;
      font-size: 1rem;
    }

    @media (min-width: 768px) {
      .hero-bottom-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2.5rem;
        align-items: end;
      }
      .hero-description { font-size: 1.125rem; line-height: 1.55; }
      .hero-cta-row { justify-content: flex-end; }
      .hero-cta { width: auto; padding: 0.75rem 1.75rem; }
    }
  </style>
</section>
