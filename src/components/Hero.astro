---
---

<section id="hero" class="relative min-h-[100svh] flex items-center overflow-hidden" style="background:var(--night);">

  <!-- Violet aurora mesh background -->
  <div class="absolute inset-0 violet-mesh"></div>

  <!-- Decorative glowing orbs -->
  <div class="orb w-[500px] h-[500px] top-[10%] right-[-10%] hidden md:block" style="background:radial-gradient(circle, rgba(168,85,247,0.5) 0%, transparent 60%);"></div>
  <div class="orb w-[400px] h-[400px] bottom-[10%] left-[-15%] hidden md:block" style="background:radial-gradient(circle, rgba(107,33,168,0.6) 0%, transparent 60%);animation-delay:-4s;"></div>
  <div class="orb w-[280px] h-[280px] top-[40%] left-[40%]" style="background:radial-gradient(circle, rgba(229,192,106,0.2) 0%, transparent 70%);animation-delay:-2s;"></div>

  <!-- Noise overlay -->
  <div class="absolute inset-0 noise-bg"></div>

  <!-- Grid lines decoration -->
  <div class="absolute inset-0 pointer-events-none hidden md:block" style="background-image: linear-gradient(rgba(216,180,254,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(216,180,254,0.04) 1px, transparent 1px); background-size: 80px 80px;"></div>

  <div class="relative z-10 w-full max-w-[1440px] mx-auto px-6 md:px-10 pt-24 md:pt-32 pb-16 md:pb-20">

    <!-- Top label + hairline -->
    <div class="hero-reveal hero-reveal-1 flex items-center gap-4 mb-10 md:mb-16">
      <span class="eyebrow eyebrow-dot" style="color:var(--lilac);">Startup tecnol&oacute;gica chilena</span>
      <div class="hairline flex-1 max-w-[200px]"></div>
    </div>

    <!-- Headline + video grid -->
    <div class="grid grid-cols-12 gap-6 md:gap-10 items-center mb-8 md:mb-10">
      <div class="col-span-12 lg:col-span-7">
        <h1 class="hero-reveal hero-reveal-2 display-xl">
          Tecnolog&iacute;a
          <span class="italic-accent">inteligente,</span>
          <br />
          a precios de pyme.
        </h1>
      </div>

      <div class="hero-reveal hero-reveal-2 col-span-12 lg:col-span-5 flex justify-center lg:justify-end">
        <div class="hero-video-wrapper">
          <video
            id="hero-video"
            class="hero-video"
            src="/video/hero-busto.mp4"
            muted
            playsinline
            preload="auto"
            disablepictureinpicture
            disableremoteplayback
            aria-hidden="true"
          ></video>
        </div>
      </div>
    </div>

    <!-- Sub + CTAs -->
    <div class="grid grid-cols-12 gap-6 md:gap-10 items-end mb-14 md:mb-20">
      <div class="col-span-12 md:col-span-6">
        <p class="hero-reveal hero-reveal-3 text-lg md:text-xl leading-relaxed max-w-xl" style="color:var(--text-muted);">
          Dise&ntilde;amos p&aacute;ginas web, automatizamos procesos con IA y construimos plataformas digitales a medida para pymes.
        </p>
      </div>

      <div class="hero-reveal hero-reveal-4 col-span-12 md:col-span-6">
        <div class="flex flex-col sm:flex-row gap-3 md:justify-end">
          <a href="/nosotros" class="btn-primary">
            Nosotros
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </div>
    </div>

  </div>

  <style>
    .hero-video-wrapper {
      position: relative;
      width: 100%;
      max-width: 420px;
      aspect-ratio: 1 / 1;
      border-radius: 18px;
      overflow: hidden;
      box-shadow: 0 30px 80px rgba(107, 33, 168, 0.45);
    }
    .hero-video-wrapper::after {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: inherit;
      border: 1px solid rgba(216, 180, 254, 0.18);
      pointer-events: none;
    }
    .hero-video {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      background: var(--midnight);
    }
    @media (max-width: 1023px) {
      .hero-video-wrapper { max-width: 340px; }
    }
    @media (max-width: 640px) {
      .hero-video-wrapper { max-width: 260px; }
    }
  </style>

  <script is:inline>
    (function () {
      const video = document.getElementById('hero-video');
      const videoWrap = video ? video.closest('.hero-video-wrapper') : null;
      if (!video || !videoWrap) return;

      let duration = 0;
      let ticking = false;

      function updateFromScroll() {
        ticking = false;
        if (!duration) return;
        const rect = videoWrap.getBoundingClientRect();
        const viewport = window.innerHeight || 1;
        // We want the video to be fully played by the time the video block has
        // scrolled ~half way up the viewport (so the tongue moment happens while
        // the bust is still clearly visible, before it slides off the top).
        // initialTop = where the video block sits when scrollY = 0
        // currentTop = rect.top (changes with scroll)
        // scrolled = how many pixels the video block has moved up
        const initialTop = rect.top + window.scrollY;
        const blockHeight = rect.height || 1;
        const scrolled = window.scrollY;
        // Map scroll so the video completes around the point where the video
        // block has scrolled ~halfway out of view — that way the bust still
        // has space on screen when the tongue moment hits.
        const range = Math.max(1, initialTop + blockHeight * 0.4);
        const progress = Math.max(0, Math.min(1, scrolled / range));
        const target = duration * progress;
        // Smooth scrubbing: only update if difference is meaningful
        if (Math.abs(video.currentTime - target) > 0.02) {
          try {
            if (typeof video.fastSeek === 'function') {
              video.fastSeek(target);
            } else {
              video.currentTime = target;
            }
          } catch (e) {}
        }
      }

      function onScroll() {
        if (!ticking) {
          ticking = true;
          requestAnimationFrame(updateFromScroll);
        }
      }

      function onMetadataReady() {
        duration = video.duration || 0;
        updateFromScroll();
      }

      if (video.readyState >= 1 && video.duration) {
        onMetadataReady();
      } else {
        video.addEventListener('loadedmetadata', onMetadataReady, { once: true });
      }

      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll, { passive: true });

      // Initial sync
      requestAnimationFrame(updateFromScroll);
    })();
  </script>
</section>
