---
const marqueeItems = [
  'Presencia digital',
  'Automatización IA',
  'ERP &amp; CRM',
  'Integración de sistemas',
  'Desarrollo a medida',
  'Chatbot inteligente',
  'Capacitaciones',
];
---

<section class="relative py-6 md:py-8 overflow-hidden border-y" style="background:var(--ink);color:var(--cream);border-color:rgba(250,247,240,0.1);">
  <div class="marquee-track gap-12 md:gap-16 whitespace-nowrap">
    {[...marqueeItems, ...marqueeItems, ...marqueeItems].map((item) => (
      <div class="flex items-center gap-12 md:gap-16 flex-shrink-0">
        <span class="font-mono-accent text-xs md:text-sm uppercase tracking-[0.2em]" style="color:var(--gold);" set:html={`• ${item}`}></span>
      </div>
    ))}
  </div>
</section>
