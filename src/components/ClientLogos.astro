---
---

<section class="relative py-16 md:py-24 overflow-hidden" style="background:var(--night);">
  <div class="relative z-10 max-w-[1440px] mx-auto px-6 md:px-10">
    <div class="marginalia mb-8 md:mb-12 uppercase tracking-[0.2em]" style="color:var(--text-muted);">
      &mdash; Empresas que confiaron en nosotros
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8 items-stretch">
      <div class="client-card">
        <img src="/img/clientes/arrimaq.png" alt="Arrimaq" loading="lazy" />
      </div>
      <div class="client-card client-card--tall">
        <img src="/img/clientes/servipag.png" alt="Servipag" loading="lazy" />
      </div>
      <div class="client-card">
        <img src="/img/clientes/curifor.png" alt="Curifor" loading="lazy" />
      </div>
      <div class="client-card">
        <img src="/img/clientes/procesos360.png" alt="Procesos 360" loading="lazy" />
      </div>
    </div>
  </div>

  <style>
    .client-card {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 8px 12px;
      min-height: 72px;
      transition: transform 0.3s ease, opacity 0.3s ease;
      opacity: 0.75;
    }
    .client-card:hover {
      opacity: 1;
      transform: translateY(-2px);
    }
    .client-card img {
      max-height: 44px;
      width: auto;
      max-width: 100%;
      object-fit: contain;
    }
    .client-card--tall img {
      max-height: 68px;
    }
    @media (max-width: 768px) {
      .client-card { padding: 6px 8px; min-height: 60px; }
      .client-card img { max-height: 34px; }
      .client-card--tall img { max-height: 54px; }
    }
  </style>
</section>
