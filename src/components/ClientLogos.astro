---
---

<section class="relative pt-8 pb-16 md:pt-12 md:pb-24 overflow-hidden" style="background:var(--night);">
  <div class="relative z-10 max-w-[1440px] mx-auto px-6 md:px-10">
    <h2 class="client-logos-title">
      Empresas que <span class="italic-accent">confiaron</span> en nosotros.
    </h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8 items-stretch">
      <div class="client-card">
        <img src="/img/clientes/arrimaq.png" alt="Arrimaq" loading="lazy" />
      </div>
      <div class="client-card client-card--tall">
        <img src="/img/clientes/servipag.png" alt="Servipag" loading="lazy" />
      </div>
      <div class="client-card">
        <img src="/img/clientes/curifor.png" alt="Curifor" loading="lazy" />
      </div>
      <div class="client-card">
        <img src="/img/clientes/procesos360.png" alt="Procesos 360" loading="lazy" />
      </div>
    </div>
  </div>

  <style>
    .client-logos-title {
      font-family: var(--font-display, 'Fraunces', serif);
      font-size: clamp(2.25rem, 5vw, 4rem);
      line-height: 1.05;
      letter-spacing: -0.03em;
      color: var(--cream);
      font-weight: 500;
      margin-bottom: 2.5rem;
      max-width: 24ch;
    }
    @media (min-width: 768px) {
      .client-logos-title { margin-bottom: 3.5rem; }
    }

    .client-card {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 8px 12px;
      min-height: 72px;
      transition: transform 0.3s ease, opacity 0.3s ease;
      opacity: 0.75;
    }
    .client-card:hover {
      opacity: 1;
      transform: translateY(-2px);
    }
    .client-card img {
      max-height: 44px;
      width: auto;
      max-width: 100%;
      object-fit: contain;
    }
    .client-card--tall img {
      max-height: 68px;
    }
    @media (max-width: 768px) {
      .client-card { padding: 6px 8px; min-height: 60px; }
      .client-card img { max-height: 34px; }
      .client-card--tall img { max-height: 54px; }
    }
  </style>
</section>
