---
const serviceOptions = [
  'Presencia Digital',
  'Automatización',
  'ERP-CRM',
  'Integración',
  'Desarrollo a Medida',
  'Chatbot',
  'Otro'
];
---

<section id="contacto" class="relative py-14 md:py-32 overflow-hidden">
  <!-- Dark background with gradient mesh -->
  <div class="absolute inset-0" style="background-color: var(--clr-dark);"></div>
  <div class="absolute inset-0 gradient-mesh opacity-60"></div>
  <div class="absolute inset-0 noise-bg"></div>

  <div class="max-w-[1280px] mx-auto px-5 sm:px-6 lg:px-8 relative z-10">
    <!-- Mobile: title + form first, info below. Desktop: side by side -->
    <div class="lg:hidden text-center mb-8 fade-up">
      <h2 class="text-2xl sm:text-3xl font-bold text-white mb-3 tracking-tight" style="font-family: var(--font-heading);">
        Hablemos de tu proyecto
      </h2>
      <p class="text-white/50 text-sm mb-0 leading-relaxed">
        Cu&eacute;ntanos qu&eacute; necesitas y te contactamos en menos de 24 horas.
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-8 lg:gap-16 items-start">
      <!-- Left: Info (hidden on mobile until after form) -->
      <div class="fade-up text-white order-2 lg:order-1">
        <!-- Desktop title -->
        <div class="hidden lg:block">
          <h2 class="text-3xl md:text-5xl font-bold mb-5 tracking-tight" style="font-family: var(--font-heading);">
            Hablemos de tu proyecto
          </h2>
          <p class="text-white/50 text-lg mb-10 leading-relaxed max-w-lg">
            Cu&eacute;ntanos qu&eacute; necesitas y te contactamos en menos de 24 horas.
          </p>
        </div>

        <!-- Contact info - horizontal on mobile, vertical on desktop -->
        <div class="grid grid-cols-3 lg:grid-cols-1 gap-4 lg:gap-6 mt-6 lg:mt-0">
          <a href="mailto:contacto@platonia.cl" class="flex flex-col lg:flex-row items-center lg:items-start gap-2 lg:gap-4 group touch-manipulation">
            <div class="w-10 h-10 lg:w-12 lg:h-12 bg-white/5 border border-white/10 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:bg-primary/20 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 lg:w-5 lg:h-5 text-primary-light" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div class="text-center lg:text-left">
              <h4 class="font-semibold text-white text-xs lg:text-sm mb-0.5" style="font-family: var(--font-heading);">Email</h4>
              <p class="text-white/40 text-[11px] lg:text-sm">contacto@platonia.cl</p>
            </div>
          </a>

          <a href="https://wa.me/56997076130" target="_blank" rel="noopener noreferrer" class="flex flex-col lg:flex-row items-center lg:items-start gap-2 lg:gap-4 group touch-manipulation">
            <div class="w-10 h-10 lg:w-12 lg:h-12 bg-white/5 border border-white/10 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:bg-primary/20 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 lg:w-5 lg:h-5 text-primary-light" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            </div>
            <div class="text-center lg:text-left">
              <h4 class="font-semibold text-white text-xs lg:text-sm mb-0.5" style="font-family: var(--font-heading);">WhatsApp</h4>
              <p class="text-white/40 text-[11px] lg:text-sm">+56 9 9707 6130</p>
            </div>
          </a>

          <div class="flex flex-col lg:flex-row items-center lg:items-start gap-2 lg:gap-4">
            <div class="w-10 h-10 lg:w-12 lg:h-12 bg-white/5 border border-white/10 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 lg:w-5 lg:h-5 text-primary-light" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div class="text-center lg:text-left">
              <h4 class="font-semibold text-white text-xs lg:text-sm mb-0.5" style="font-family: var(--font-heading);">Ubicaci&oacute;n</h4>
              <p class="text-white/40 text-[11px] lg:text-sm">Santiago, Chile</p>
            </div>
          </div>
        </div>

        <!-- Social links -->
        <div class="flex gap-3 mt-8 lg:mt-10 justify-center lg:justify-start">
          <a href="#" class="w-10 h-10 bg-white/5 border border-white/10 hover:bg-primary/30 hover:border-primary/40 rounded-lg flex items-center justify-center transition-all duration-300 touch-manipulation" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4.5 h-4.5 text-white/60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
          <a href="#" class="w-10 h-10 bg-white/5 border border-white/10 hover:bg-primary/30 hover:border-primary/40 rounded-lg flex items-center justify-center transition-all duration-300 touch-manipulation" aria-label="LinkedIn">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4.5 h-4.5 text-white/60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
          </a>
          <a href="https://wa.me/56997076130" target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-white/5 border border-white/10 hover:bg-primary/30 hover:border-primary/40 rounded-lg flex items-center justify-center transition-all duration-300 touch-manipulation" aria-label="WhatsApp">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4.5 h-4.5 text-white/60" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </a>
        </div>
      </div>

      <!-- Right: Form (shows first on mobile) -->
      <div class="fade-up order-1 lg:order-2">
        <form id="contact-form" class="bg-white rounded-2xl p-5 sm:p-6 md:p-8 shadow-2xl space-y-4 md:space-y-5 border border-gray-100">
          <div>
            <label for="nombre" class="block text-sm font-semibold text-text-main mb-1.5" style="font-family: var(--font-heading);">Nombre completo *</label>
            <input type="text" id="nombre" name="nombre" required placeholder="Ej: Juan Pérez"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all text-base sm:text-sm bg-gray-50/50" />
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 md:gap-5">
            <div>
              <label for="email" class="block text-sm font-semibold text-text-main mb-1.5" style="font-family: var(--font-heading);">Email *</label>
              <input type="email" id="email" name="email" required placeholder="tu@email.com"
                class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all text-base sm:text-sm bg-gray-50/50" />
            </div>
            <div>
              <label for="telefono" class="block text-sm font-semibold text-text-main mb-1.5" style="font-family: var(--font-heading);">Tel&eacute;fono (WhatsApp)</label>
              <input type="tel" id="telefono" name="telefono" placeholder="+56 9 XXXX XXXX"
                class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all text-base sm:text-sm bg-gray-50/50" />
            </div>
          </div>

          <div>
            <label for="empresa" class="block text-sm font-semibold text-text-main mb-1.5" style="font-family: var(--font-heading);">Nombre de tu empresa</label>
            <input type="text" id="empresa" name="empresa" placeholder="Ej: Panadería Don José"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all text-base sm:text-sm bg-gray-50/50" />
          </div>

          <div>
            <label for="servicio" class="block text-sm font-semibold text-text-main mb-1.5" style="font-family: var(--font-heading);">&iquest;Qu&eacute; servicio te interesa? *</label>
            <select id="servicio" name="servicio" required
              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all text-base sm:text-sm bg-gray-50/50 text-text-muted">
              <option value="" disabled selected>Selecciona una opci&oacute;n</option>
              {serviceOptions.map(opt => (
                <option value={opt}>{opt}</option>
              ))}
            </select>
          </div>

          <div class="relative">
            <label for="dolor" class="block text-sm font-semibold text-text-main mb-1.5" style="font-family: var(--font-heading);">
              <span class="flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
                &iquest;Cu&aacute;l es tu mayor desaf&iacute;o digital? *
              </span>
            </label>
            <textarea id="dolor" name="dolor" required rows="4" placeholder="Cuéntanos qué problema quieres resolver..."
              class="w-full px-4 py-3 rounded-xl border-2 border-primary/15 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all text-base sm:text-sm bg-primary/[0.02] resize-none"></textarea>
          </div>

          <button type="submit" class="btn-primary w-full !py-4 !text-base !rounded-xl touch-manipulation">
            Enviar mensaje
          </button>

          <div id="form-success" class="hidden text-center py-4">
            <div class="w-14 h-14 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-3">
              <svg class="w-7 h-7 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
              </svg>
            </div>
            <div class="text-green-700 font-bold text-lg mb-1" style="font-family: var(--font-heading);">&iexcl;Gracias!</div>
            <p class="text-text-muted text-sm">Tu mensaje fue recibido. Te contactaremos en menos de 24 horas.</p>
          </div>

          <div id="form-error" class="hidden text-center py-2">
            <p class="text-red-500 text-sm">Por favor completa todos los campos obligatorios.</p>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successMsg = document.getElementById('form-success')!;
  const errorMsg = document.getElementById('form-error')!;

  form.addEventListener('submit', (e) => {
    e.preventDefault();

    const formData = new FormData(form);
    const nombre = formData.get('nombre');
    const email = formData.get('email');
    const servicio = formData.get('servicio');
    const dolor = formData.get('dolor');

    if (!nombre || !email || !servicio || !dolor) {
      errorMsg.classList.remove('hidden');
      setTimeout(() => errorMsg.classList.add('hidden'), 3000);
      return;
    }

    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    submitBtn.disabled = true;
    submitBtn.innerHTML = '<svg class="animate-spin w-5 h-5 mr-2" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg> Enviando...';

    setTimeout(() => {
      form.classList.add('hidden');
      successMsg.classList.remove('hidden');
      successMsg.parentElement?.classList.remove('hidden');
    }, 1200);
  });
</script>
