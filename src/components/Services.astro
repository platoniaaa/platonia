---
const services = [
  {
    title: 'Páginas Web a Medida',
    description: 'Diseñamos sitios web, landing pages y tiendas online optimizadas para Google y pensadas para generar confianza desde el primer scroll.',
  },
  {
    title: 'Automatización con IA',
    description: 'Capturamos las tareas repetitivas de tu equipo —facturación, atención por WhatsApp, reportes— y las convertimos en flujos que corren solos.',
  },
  {
    title: 'Gestión de Negocio',
    description: 'ERP y CRM que centralizan ventas, inventario, finanzas y clientes en un solo lugar. Adiós a las planillas dispersas y al doble registro.',
  },
  {
    title: 'Integración de Sistemas',
    description: 'Conectamos las herramientas que ya usas para que la información fluya entre ellas sin intervención manual ni copy-paste.',
  },
  {
    title: 'Desarrollo a Medida',
    description: 'Cuando ninguna solución estándar encaja, la construimos: plataformas, apps móviles, dashboards y portales internos a la medida.',
  },
];
---

<section id="servicios" class="relative py-24 md:py-36 overflow-hidden" style="background:var(--night);">

  <!-- Subtle ambient glow -->
  <div class="orb w-[500px] h-[500px] top-[20%] left-[-15%] hidden md:block" style="background:radial-gradient(circle, rgba(168,85,247,0.10) 0%, transparent 65%);"></div>

  <div class="relative z-10 max-w-[1440px] mx-auto px-6 md:px-10">

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20">

      <!-- LEFT: title + description + CTA -->
      <div class="lg:col-span-5 lg:sticky lg:top-32 lg:self-start fade-up">
        <h2 class="services-title">
          &iquest;Qu&eacute; <span class="italic-accent">hacemos?</span>
        </h2>

        <p
          id="services-description"
          class="services-description"
          data-default="Soluciones tecnol&oacute;gicas a medida para pymes: desde la presencia digital hasta automatizaciones con IA. Pasa el cursor sobre cada servicio para conocer m&aacute;s."
        >
          Soluciones tecnol&oacute;gicas a medida para pymes: desde la presencia digital hasta automatizaciones con IA. Pasa el cursor sobre cada servicio para conocer m&aacute;s.
        </p>

        <a href="#contacto" class="services-cta">
          Conversemos
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>

      <!-- RIGHT: services list -->
      <div class="lg:col-span-7 fade-up">
        <ul class="services-list" id="services-list">
          {services.map((service, i) => (
            <li
              class="services-item"
              data-description={service.description}
              tabindex="0"
            >
              <span class="services-item__label">{service.title}</span>
            </li>
          ))}
        </ul>
      </div>

    </div>
  </div>

  <style>
    .services-title {
      font-family: var(--font-display, 'Fraunces', serif);
      font-size: clamp(3rem, 6vw, 5.5rem);
      line-height: 0.95;
      letter-spacing: -0.03em;
      color: var(--cream);
      font-weight: 500;
      margin-bottom: 2rem;
    }

    .services-description {
      font-size: 1.0625rem;
      line-height: 1.65;
      color: var(--text-muted);
      max-width: 32rem;
      margin-bottom: 2.5rem;
      min-height: 6rem;
      transition: opacity 0.25s ease;
    }

    .services-description.is-fading {
      opacity: 0;
    }

    .services-cta {
      display: inline-flex;
      align-items: center;
      gap: 0.625rem;
      padding: 0.875rem 1.75rem;
      border-radius: 999px;
      background: var(--lilac, #a855f7);
      color: var(--night, #0d0820);
      font-weight: 600;
      font-size: 0.9375rem;
      transition: transform 0.25s ease, box-shadow 0.25s ease, background 0.25s ease;
    }
    .services-cta:hover {
      transform: translateY(-2px);
      background: #c084fc;
      box-shadow: 0 12px 32px rgba(168,85,247,0.35);
    }

    .services-list {
      list-style: none;
      padding: 0;
      margin: 0;
      border-top: 1px solid rgba(216,180,254,0.15);
    }

    .services-item {
      padding: 1.5rem 0;
      border-bottom: 1px solid rgba(216,180,254,0.15);
      cursor: pointer;
      transition: padding-left 0.3s ease;
      outline: none;
    }
    .services-item:focus-visible {
      padding-left: 0.75rem;
    }

    .services-item__label {
      font-family: var(--font-display, 'Fraunces', serif);
      font-size: clamp(1.75rem, 3.2vw, 2.75rem);
      line-height: 1.1;
      letter-spacing: -0.02em;
      font-weight: 500;
      color: var(--cream);
      transition: color 0.3s ease, transform 0.3s ease;
      display: inline-block;
    }

    .services-item:hover .services-item__label,
    .services-item.is-active .services-item__label,
    .services-item:focus-visible .services-item__label {
      color: var(--lilac, #a855f7);
    }

    @media (min-width: 1024px) {
      .services-item {
        padding: 1.75rem 0;
      }
    }
  </style>

  <script is:inline>
    (function () {
      const list = document.getElementById('services-list');
      const desc = document.getElementById('services-description');
      if (!list || !desc) return;

      const items = list.querySelectorAll('.services-item');
      const defaultText = desc.getAttribute('data-default') || desc.textContent;

      function setDescription(text) {
        if (desc.textContent.trim() === text.trim()) return;
        desc.classList.add('is-fading');
        setTimeout(() => {
          desc.textContent = text;
          desc.classList.remove('is-fading');
        }, 180);
      }

      function activate(item) {
        items.forEach((el) => el.classList.remove('is-active'));
        item.classList.add('is-active');
        setDescription(item.getAttribute('data-description'));
      }

      function deactivate() {
        items.forEach((el) => el.classList.remove('is-active'));
        setDescription(defaultText);
      }

      items.forEach((item) => {
        item.addEventListener('mouseenter', () => activate(item));
        item.addEventListener('focus', () => activate(item));
        item.addEventListener('click', () => activate(item));
      });

      list.addEventListener('mouseleave', deactivate);
    })();
  </script>
</section>
