---
const services = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 md:w-7 md:h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8"/><path d="M12 17v4"/><circle cx="12" cy="10" r="3"/></svg>`,
    title: 'Presencia Digital',
    description: 'Diseñamos tu cara digital: sitios web, landing pages y tiendas online optimizadas para Google y que generan confianza.',
    link: 'Saber más →'
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 md:w-7 md:h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>`,
    title: 'Automatización Inteligente',
    description: 'Automatizamos tus procesos con IA: facturación, atención al cliente por WhatsApp, reportes y más.',
    link: 'Saber más →'
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 md:w-7 md:h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/><path d="M13 15h4"/><path d="M13 12h4"/></svg>`,
    title: 'Gestión de Negocio',
    description: 'ERP y CRM que centralizan toda tu operación: ventas, inventario, finanzas y clientes.',
    link: 'Saber más →'
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 md:w-7 md:h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>`,
    title: 'Integración de Sistemas',
    description: 'Conectamos tus herramientas para que la información fluya sin intervención manual.',
    link: 'Saber más →'
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 md:w-7 md:h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/><line x1="12" y1="2" x2="12" y2="22"/></svg>`,
    title: 'Desarrollo a Medida',
    description: 'Si ningún software del mercado resuelve tu desafío, lo construimos con metodologías ágiles.',
    link: 'Saber más →'
  },
];
---

<section id="servicios" class="relative py-14 md:py-32 bg-white noise-bg overflow-hidden">
  <div class="max-w-[1280px] mx-auto px-5 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-10 md:mb-20 fade-up">
      <h2 class="section-title">Soluciones digitales para cada desaf&iacute;o</h2>
      <p class="section-subtitle">
        Nuestros servicios se organizan por lo que tu negocio necesita resolver.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-8">
      {services.map((service, i) => (
        <div
          class="fade-up group relative bg-white border border-gray-100 rounded-2xl p-5 md:p-8 transition-all duration-300 hover:border-primary/30 hover:-translate-y-1.5"
          style={`transition-delay: ${i * 100}ms`}
        >
          <div class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-300" style="box-shadow: 0 10px 40px rgba(107, 33, 168, 0.12);"></div>

          <div class="relative z-10">
            <div class="w-12 h-12 md:w-14 md:h-14 rounded-xl bg-gradient-to-br from-primary to-primary-light flex items-center justify-center text-white mb-4 md:mb-6 shadow-purple">
              <Fragment set:html={service.icon} />
            </div>
            <h3 class="text-lg md:text-xl font-bold text-text-main mb-2 md:mb-3" style="font-family: var(--font-heading);">{service.title}</h3>
            <p class="text-text-muted leading-relaxed mb-3 md:mb-4 text-sm md:text-[0.95rem]">{service.description}</p>
            <a href="#contacto" class="inline-flex items-center text-primary font-semibold text-sm hover:text-primary-light transition-colors touch-manipulation py-1">
              {service.link}
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
