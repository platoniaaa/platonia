---
const services = [
  {
    num: '02',
    title: 'Presencia Digital',
    italic: 'para que te encuentren',
    description: 'Sitios web, landing pages y tiendas online optimizadas para Google y diseñadas para generar confianza.',
    body: 'Diseño responsivo, dominio, hosting, SEO, formularios inteligentes y panel de administración propio.',
  },
  {
    num: '03',
    title: 'Automatización Inteligente',
    italic: 'para recuperar tiempo',
    description: 'Automatizamos procesos con IA: facturación, atención al cliente, reportes y sincronización de datos.',
    body: 'Diagnóstico de procesos, diseño del flujo, implementación, capacitación y 3 meses de soporte.',
  },
  {
    num: '04',
    title: 'Gestión de Negocio',
    italic: 'para ver todo claro',
    description: 'ERP y CRM que centralizan ventas, inventario, finanzas y clientes. Adiós planillas de Excel.',
    body: 'Levantamiento de procesos, configuración, migración de datos, capacitación y soporte continuo.',
  },
  {
    num: '05',
    title: 'Integración de Sistemas',
    italic: 'para que hablen entre sí',
    description: 'Conectamos tus herramientas para que la información fluya sin intervención manual.',
    body: 'Auditoría, diseño de arquitectura, desarrollo de conectores, pruebas y monitoreo continuo.',
  },
  {
    num: '06',
    title: 'Desarrollo a Medida',
    italic: 'para lo que no existe',
    description: 'Cuando ninguna solución estándar encaja, la construimos. Plataformas, apps, dashboards y portales.',
    body: 'Análisis de requerimientos, prototipado, desarrollo iterativo, pruebas y garantía post-entrega.',
  },
];
---

<section id="servicios" class="relative py-20 md:py-32 paper-grain" style="background:var(--ivory);">
  <div class="max-w-[1440px] mx-auto px-6 md:px-10 relative z-10">

    <!-- Section header editorial style -->
    <div class="grid grid-cols-12 gap-4 md:gap-8 mb-16 md:mb-24 fade-up">
      <div class="col-span-12 md:col-span-3">
        <div class="eyebrow eyebrow-dot mb-4">Secci&oacute;n I</div>
        <div class="hairline w-16"></div>
      </div>
      <div class="col-span-12 md:col-span-9">
        <h2 class="display-lg" style="color:var(--ink);">
          Servicios dise&ntilde;ados por
          <span class="italic-accent">lo que resuelven,</span>
          no por su tecnolog&iacute;a.
        </h2>
      </div>
    </div>

    <!-- Editorial numbered list -->
    <div class="grid grid-cols-12 gap-0">
      {services.map((service, i) => (
        <div class="col-span-12 fade-up" style={`transition-delay: ${i * 100}ms`}>
          <div class="grid grid-cols-12 gap-4 md:gap-8 py-10 md:py-14 border-t group" style="border-color:rgba(26,22,20,0.12);">

            <!-- Number -->
            <div class="col-span-2 md:col-span-1">
              <span class="font-mono-accent text-sm" style="color:var(--sepia);">{service.num}</span>
            </div>

            <!-- Title + italic -->
            <div class="col-span-10 md:col-span-5">
              <h3 class="display-md mb-2" style="color:var(--ink);">
                {service.title}
              </h3>
              <p class="italic-accent text-base md:text-lg" style="font-family:var(--font-display);font-weight:300;">
                &mdash; {service.italic}
              </p>
            </div>

            <!-- Description -->
            <div class="col-span-12 md:col-span-5 md:col-start-7">
              <p class="text-base md:text-lg leading-relaxed mb-4" style="color:var(--ink-soft);">
                {service.description}
              </p>
              <p class="text-sm leading-relaxed mb-5" style="color:var(--ash);">
                {service.body}
              </p>
              <a href="#contacto" class="inline-flex items-center gap-2 text-sm font-medium link-underline" style="color:var(--ink);">
                <span>Conversemos</span>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
            </div>

            <!-- Spacer column -->
            <div class="hidden md:block md:col-span-1"></div>
          </div>
        </div>
      ))}
      <div class="col-span-12 border-t" style="border-color:rgba(26,22,20,0.12);"></div>
    </div>
  </div>
</section>
