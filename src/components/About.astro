---
const values = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>`,
    title: 'Accesibilidad',
    description: 'Tecnología de alto nivel al alcance de todos.'
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>`,
    title: 'Innovación con propósito',
    description: 'IA y tecnología donde realmente agregan valor.'
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>`,
    title: 'Cercanía',
    description: 'Hablamos tu idioma y entendemos tu negocio.'
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>`,
    title: 'Excelencia técnica',
    description: 'Cada línea de código refleja nuestro compromiso.'
  }
];
---

<section id="nosotros" class="relative py-14 md:py-32 bg-cream overflow-hidden">
  <!-- Noise texture -->
  <div class="absolute inset-0 noise-bg"></div>

  <div class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid lg:grid-cols-[1.2fr_0.8fr] gap-12 md:gap-20 items-center">
      <!-- Text side (60%) -->
      <div class="fade-up">
        <h2 class="text-2xl sm:text-3xl md:text-5xl font-bold text-text-main mb-5 md:mb-8 tracking-tight" style="font-family: var(--font-heading);">
          Somos Platonia
        </h2>
        <p class="text-base md:text-lg text-text-muted mb-5 leading-relaxed">
          Nuestro nombre combina la sabidur&iacute;a cl&aacute;sica de <strong class="text-text-main">Plat&oacute;n</strong> con la vanguardia de la <strong class="text-text-main">inteligencia artificial</strong>. Somos una startup chilena fundada con un prop&oacute;sito claro: hacer que las herramientas m&aacute;s poderosas del mundo digital est&eacute;n al alcance de las pymes.
        </p>

        <!-- Mission -->
        <div class="bg-white rounded-xl p-5 border-l-4 border-primary mb-8 shadow-purple">
          <p class="text-sm font-bold text-primary uppercase tracking-wider mb-1 font-mono-accent">Nuestra misi&oacute;n</p>
          <p class="text-text-main leading-relaxed">
            Democratizar el acceso a soluciones digitales de alto nivel para pymes y microempresas.
          </p>
        </div>

        <!-- Values grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {values.map(value => (
            <div class="flex items-start gap-3 p-4 rounded-xl bg-white hover:shadow-purple transition-all duration-300">
              <div class="w-9 h-9 rounded-lg bg-primary/10 flex items-center justify-center text-primary flex-shrink-0 mt-0.5">
                <Fragment set:html={value.icon} />
              </div>
              <div>
                <h4 class="font-bold text-text-main text-sm" style="font-family: var(--font-heading);">{value.title}</h4>
                <p class="text-text-muted text-sm">{value.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Visual side (40%) - Isotipo decorative -->
      <div class="fade-up hidden lg:flex items-center justify-center relative">
        <!-- Large decorative isotipo -->
        <div class="relative">
          <div class="w-72 h-72 xl:w-80 xl:h-80 rounded-3xl bg-gradient-to-br from-primary/5 to-primary-light/10 flex items-center justify-center border border-primary/10">
            <span class="text-[180px] xl:text-[200px] font-bold text-primary/10 leading-none select-none" style="font-family: var(--font-heading);">P</span>
          </div>
          <!-- Floating accent -->
          <div class="absolute -bottom-6 -right-6 bg-white rounded-2xl p-5 shadow-purple-lg border border-gray-100">
            <p class="text-xs text-text-muted mb-1 font-mono-accent">Startup tecnol&oacute;gica</p>
            <p class="text-sm font-bold text-text-main">Santiago, Chile</p>
          </div>
          <div class="absolute -top-4 -left-4 w-20 h-20 rounded-full bg-primary-light/10 blur-2xl"></div>
        </div>

        <!-- Lema -->
        <div class="absolute bottom-0 left-0 right-0 text-center mt-8">
          <p class="text-text-muted/60 italic text-sm leading-relaxed max-w-xs mx-auto">
            &ldquo;La sabidur&iacute;a de hacer las cosas bien, con la inteligencia de hacerlas mejor.&rdquo;
          </p>
        </div>
      </div>
    </div>

    <!-- Mobile lema -->
    <div class="lg:hidden mt-10 text-center fade-up">
      <p class="text-text-muted/60 italic text-sm leading-relaxed">
        &ldquo;La sabidur&iacute;a de hacer las cosas bien, con la inteligencia de hacerlas mejor.&rdquo;
      </p>
    </div>
  </div>
</section>
